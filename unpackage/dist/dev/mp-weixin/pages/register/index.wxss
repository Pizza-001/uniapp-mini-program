/* ===== 宠爱之城 3.0 高级轻医疗设计系统升级 ===== */
.register-page {
  min-height: 100vh;
  background-color: #f8f9fa;
  position: relative;
  overflow: hidden;
}
.bg-decoration {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #FF7043, #FFAB91);
  border-radius: 50%;
  opacity: 0.1;
}
.content {
  padding: 60rpx 40rpx;
  position: relative;
  z-index: 1;
}
.header {
  margin-bottom: 60rpx;
}
.header .back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  margin-left: -20rpx;
  margin-bottom: 20rpx;
}
.header .title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.header .subtitle {
  font-size: 26rpx;
  color: #999;
}
.form-card {
  background-color: #fff;
  padding: 60rpx 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}
.input-group {
  margin-bottom: 40rpx;
}
.input-item {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}
.input-item .input {
  flex: 1;
  margin-left: 20rpx;
  font-size: 28rpx;
}
.captcha-item {
  background-color: transparent;
  padding: 0;
  justify-content: space-between;
}
.captcha-item .captcha-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}
.captcha-item .captcha-img {
  width: 200rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background-color: #eee;
}
.register-btn {
  background: linear-gradient(to right, #FF7043, #FF8A65);
  color: #fff;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(255, 112, 67, 0.3);
  margin-bottom: 40rpx;
}
.register-btn::after {
  border: none;
}
.login-tip {
  text-align: center;
  font-size: 26rpx;
  color: #666;
}
.login-tip .link {
  color: #FF7043;
  margin-left: 10rpx;
  font-weight: bold;
}
.agreement {
  padding: 0 20rpx;
}
.agreement .checkbox {
  display: flex;
  align-items: flex-start;
}
.agreement .checkbox .text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  margin-left: 10rpx;
}
.agreement .checkbox .text .highlight {
  color: #FF7043;
}