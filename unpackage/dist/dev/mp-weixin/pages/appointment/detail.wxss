/* ===== 宠爱之城 3.0 高级轻医疗设计系统升级 ===== */
.detail-page {
  min-height: 100vh;
  background-color: #f8f9fa;
}
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 88rpx;
  padding-top: var(--status-bar-height);
  display: flex;
  align-items: center;
  padding-left: 30rpx;
  background-color: #FF7043;
}
.header .back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}
.header .header-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 20rpx;
}
.status-header {
  height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF7043, #FF8A65);
  padding-top: var(--status-bar-height);
}
.status-header.status-1 {
  background: linear-gradient(135deg, #4CAF50, #81C784);
}
.status-header.status-2 {
  background: linear-gradient(135deg, #999, #ccc);
}
.status-header .status-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.content {
  padding: 30rpx;
  margin-top: -40rpx;
}
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #FF7043;
  padding-left: 20rpx;
}
.info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.info-item .label {
  font-size: 26rpx;
  color: #999;
}
.info-item .value {
  font-size: 26rpx;
  color: #333;
}
.symptom-box {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
}
.symptom-box .symptom-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
.bottom-bar {
  padding: 40rpx 30rpx;
}
.bottom-bar .cancel-btn {
  background-color: #fff;
  color: #999;
  border: 1rpx solid #eee;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
}