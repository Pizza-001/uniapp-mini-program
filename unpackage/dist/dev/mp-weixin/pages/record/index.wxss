/* ===== 宠爱之城 3.0 高级轻医疗设计系统升级 ===== */
.record-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f9fa;
}
.tab-bar {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
  height: 88rpx;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-bar .tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-bar .tab-item.active {
  color: #FF7043;
  font-weight: bold;
}
.tab-bar .tab-item.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #FF7043;
  border-radius: 3rpx;
}
.list-scroll {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}
.card {
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 30rpx;
}
.record-card {
  padding: 30rpx;
}
.record-card .card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}
.record-card .card-header .type-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.record-card .card-header .type-tag.vaccine {
  background-color: #E3F2FD;
  color: #42A5F5;
}
.record-card .card-header .type-tag.normal {
  background-color: #FFF3E0;
  color: #FF7043;
}
.record-card .card-header .status {
  font-size: 24rpx;
  font-weight: bold;
}
.record-card .card-header .status.status-0 {
  color: #FF7043;
}
.record-card .card-header .status.status-1 {
  color: #4CAF50;
}
.record-card .card-header .status.status-2 {
  color: #999;
}
.record-card .card-body .info-row {
  display: flex;
  margin-bottom: 12rpx;
}
.record-card .card-body .info-row .label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
}
.record-card .card-body .info-row .value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.record-card .card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f5f5f5;
}
.record-card .card-footer .action-btn {
  margin: 0;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 30rpx;
  border-radius: 30rpx;
  background-color: #FF7043;
  color: #fff;
  border: none;
}
.record-card .card-footer .action-btn.outline {
  background-color: transparent;
  color: #999;
  border: 2rpx solid #eee;
}
.record-card .card-footer .action-btn::after {
  border: none;
}
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-state .empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}
.empty-state .empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.empty-state .go-btn {
  background-color: #FF7043;
  color: #fff;
  padding: 0 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.footer-spacing {
  height: 40rpx;
}