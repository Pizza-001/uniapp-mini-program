<view class="record-page"><view class="tab-bar"><view wx:for="{{a}}" wx:for-item="item" wx:key="c" class="{{['tab-item', item.b && 'active']}}" bindtap="{{item.d}}">{{item.a}}</view></view><scroll-view class="list-scroll" scroll-y refresher-enabled refresher-triggered="{{e}}" bindrefresherrefresh="{{f}}"><view wx:if="{{b}}" class="empty-state"><image class="empty-img" src="https://dummyimage.com/300x300/f5f5f5/999&text=No+Data" mode="aspectFit"/><text class="empty-text">暂无预约记录</text><button class="go-btn" bindtap="{{c}}">立即预约</button></view><view wx:for="{{d}}" wx:for-item="item" wx:key="p" class="record-card card"><view class="card-header"><view class="{{['type-tag', item.b]}}">{{item.a}}</view><text class="{{['status', item.d]}}">{{item.c}}</text></view><view class="card-body"><view class="info-row"><text class="label">宠物信息：</text><text class="value">{{item.e}} ({{item.f}})</text></view><view class="info-row"><text class="label">预约时间：</text><text class="value">{{item.g}} {{item.h}}</text></view><view wx:if="{{item.i}}" class="info-row"><text class="label">预约医生：</text><text class="value">{{item.j}}</text></view><view wx:if="{{item.k}}" class="info-row"><text class="label">症状描述：</text><text class="value">{{item.l}}</text></view></view><view class="card-footer"><button wx:if="{{item.m}}" class="action-btn outline" bindtap="{{item.n}}">取消预约</button><button class="action-btn" bindtap="{{item.o}}">查看详情</button></view></view><view class="footer-spacing"></view></scroll-view></view>