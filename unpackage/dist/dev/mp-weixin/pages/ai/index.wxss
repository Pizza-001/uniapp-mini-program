/* ===== 宠爱之城 3.0 高级轻医疗设计系统升级 ===== */
.ai-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f6f7;
}
.chat-scroll {
  flex: 1;
  padding: 0 30rpx;
  box-sizing: border-box;
}
.chat-container {
  padding-top: 30rpx;
}
.message-wrapper {
  display: flex;
  margin-bottom: 40rpx;
}
.message-wrapper .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #fff;
  flex-shrink: 0;
}
.message-wrapper .bubble {
  max-width: 70%;
  padding: 20rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  line-height: 1.5;
  position: relative;
  word-break: break-all;
}
.message-wrapper.assistant {
  flex-direction: row;
}
.message-wrapper.assistant .bubble {
  margin-left: 20rpx;
  background-color: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}
.message-wrapper.user {
  flex-direction: row-reverse;
}
.message-wrapper.user .bubble {
  margin-right: 20rpx;
  background-color: #FF7043;
  color: #fff;
  border-top-right-radius: 4rpx;
}
.typing {
  display: flex;
  gap: 8rpx;
  padding: 10rpx 0;
}
.typing .dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #ccc;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}
.typing .dot:nth-child(1) {
  animation-delay: -0.32s;
}
.typing .dot:nth-child(2) {
  animation-delay: -0.16s;
}
@keyframes bounce {
0%, 80%, 100% {
    transform: scale(0);
}
40% {
    transform: scale(1);
}
}
.input-area {
  padding: 20rpx 30rpx 60rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
}
.input-area .input-wrapper {
  display: flex;
  align-items: flex-end;
  background-color: #f8f8f8;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
}
.input-area .input-wrapper .input {
  flex: 1;
  padding: 16rpx 0;
  font-size: 28rpx;
  max-height: 200rpx;
}
.input-area .input-wrapper .send-btn {
  width: 70rpx;
  height: 70rpx;
  background-color: #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  margin-bottom: 6rpx;
  transition: all 0.2s;
}
.input-area .input-wrapper .send-btn.active {
  background-color: #FF7043;
}
.spacing {
  height: 200rpx;
}