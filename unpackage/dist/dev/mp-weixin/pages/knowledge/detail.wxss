/* ===== 宠爱之城 3.0 高级轻医疗设计系统升级 ===== */
.detail-page {
  height: 100vh;
  background-color: #fff;
  display: flex;
  flex-direction: column;
}
.header {
  background-color: #FF7043;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  height: 88rpx;
  padding-top: var(--status-bar-height);
  box-sizing: content-box;
}
.content-scroll {
  flex: 1;
}
.article-header {
  padding: 40rpx 30rpx;
}
.article-header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  display: block;
  margin-bottom: 24rpx;
}
.article-header .meta {
  display: flex;
  font-size: 24rpx;
  color: #999;
}
.article-header .meta .author {
  color: #FF7043;
  margin-right: 24rpx;
}
.video-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}
.video-section .video {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background-color: #000;
}
.article-content {
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
}
.tags-section {
  padding: 40rpx 30rpx;
  display: flex;
  gap: 20rpx;
}
.tags-section .tag {
  font-size: 24rpx;
  color: #FF7043;
  background-color: #FFF3E0;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}
.spacing {
  height: 60rpx;
}